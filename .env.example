# Copy to .env.local and fill in. Never commit .env.local.

# --- Postgres (Supabase) -----------------------------------------------------
# App connection: Supabase TRANSACTION POOLER, port 6543. Must run prepare:false.
# Supabase dashboard → Project Settings → Database → Connection string → "Transaction".
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# Migration connection: DIRECT connection, port 5432. Used by drizzle-kit + seed.
# Supabase dashboard → same page → "Direct connection".
DIRECT_DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Supabase Auth (public, safe to expose to the browser) -------------------
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"

# Service role key (server-only, NEVER expose to the browser). Optional for now;
# needed if/when we mutate storage or bypass RLS from server actions.
# SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
